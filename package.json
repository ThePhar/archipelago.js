{
  "name": "archipelago.js",
  "version": "0.5.0-dev",
  "description": "A general-purpose client library for communicating with Archipelago game servers, written for Node.js.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "types/index.d.ts",
  "author": {
    "email": "zach@alliware.com",
    "name": "Zach Parks",
    "url": "https://pharmakesbad.software"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "engines": {
    "node": ">= 14.0.0"
  },
  "scripts": {
    "build:docs": "rimraf -rf docs && typedoc --options typedoc.json",
    "build:module": "rimraf -rf dist && tsc",
    "build:web": "rimraf -rf web && webpack",
    "build": "npm run build:module && npm run build:web && npm run build:docs",
    "lint": "eslint src && eslint tests",
    "prepack": "npm test && npm lint && npm run build",
    "prepare": "husky install",
    "test": "mocha -r ts-node/register tests/**/*.test.ts"
  },
  "homepage": "https://thephar.github.io/archipelago.js/",
  "repository": "https://github.com/ThePhar/archipelago.js.git",
  "bugs": "https://github.com/ThePhar/archipelago.js/issues",
  "keywords": [
    "archipelago",
    "client-library",
    "game-library",
    "library",
    "multi-world",
    "multiworld",
    "websocket"
  ],
  "dependencies": {
    "isomorphic-ws": "^4.0.1",
    "ws": "^8.8.0"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^3.2.0",
    "@types/chai": "^4.3.1",
    "@types/mocha": "^9.1.1",
    "@types/node": "^17.0.42",
    "@types/ws": "^8.5.3",
    "@typescript-eslint/eslint-plugin": "^5.27.1",
    "@typescript-eslint/parser": "^5.27.1",
    "chai": "^4.3.6",
    "eslint": "^8.17.0",
    "eslint-config-prettier": "^8.5.0",
    "eslint-plugin-tsdoc": "^0.2.16",
    "husky": "^8.0.1",
    "mocha": "^10.0.0",
    "prettier": "^2.6.2",
    "prettier-plugin-jsdoc": "^0.3.38",
    "rimraf": "^3.0.2",
    "ts-loader": "^9.3.0",
    "ts-node": "^10.8.1",
    "typedoc": "^0.22.17",
    "typescript": "^4.7.3",
    "webpack": "^5.73.0",
    "webpack-cli": "^4.10.0"
  }
}
